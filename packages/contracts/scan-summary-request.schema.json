{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScanSummaryRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["caseId", "detectedSignals", "riskLevel"],
  "properties": {
    "caseId": {
      "type": "string"
    },
    "detectedSignals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "riskLevel": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH"]
    }
  }
}
