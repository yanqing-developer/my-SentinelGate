{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScanSummaryRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["caseId", "detectedSignals", "riskLevel", "recommendation"],
  "properties": {
    "caseId": {
      "type": "string"
    },
    "detectedSignals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "ruleId", "label", "severity"],
        "properties": {
          "type": {
            "type": "string"
          },
          "ruleId": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH"]
          }
        }
      }
    },
    "riskLevel": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH"]
    },
    "recommendation": {
      "type": "string",
      "enum": ["ALLOW", "WARN", "BLOCK"]
    }
  }
}
